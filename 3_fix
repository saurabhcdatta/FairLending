/* Diagnostic: full peer_scored distribution before threshold filtering */
proc univariate data=work.peer_scored;
    var overlap_score n_shared_tracts peer_total_origs peer_concentration;
run;

proc print data=work.peer_scored (obs=30);
    title "Top 30 peers by overlap_score - pre-threshold";
    var join_number overlap_score n_shared_tracts peer_total_origs peer_concentration;
run;

/* And: how many CUs were even in the candidate pool? */
proc sql;
    select count(*) as n_eligible_cus from work.cu_eligible;
quit;

/* What's the geographic distribution of ESL's volume? */
proc print data=work.esl_tract_dist (obs=20);
    title "ESL top 20 tracts by volume";
run;