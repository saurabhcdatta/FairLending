proc means data=work.analy_loans n nmiss mean median min max;
    var Interest_Rate_Min_PMMS_1 Discount_Points_LA 
        Lender_Credits_LA Loan_Cost_Prc_LA;
    class role;
run;

/* And check what fraction are actual zeros vs missing */
proc sql;
    select role,
           sum(Discount_Points_LA = 0)         as zeros_disc,
           sum(missing(Discount_Points_LA))    as miss_disc,
           sum(Lender_Credits_LA = 0)          as zeros_cred,
           sum(missing(Lender_Credits_LA))     as miss_cred,
           sum(Loan_Cost_Prc_LA = 0)           as zeros_cost,
           sum(missing(Loan_Cost_Prc_LA))      as miss_cost,
           count(*)                            as n_total
    from work.analy_loans
    group by role;
quit;