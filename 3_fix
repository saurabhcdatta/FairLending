/* Find all fee/cost components in the dataset */
proc sql;
  select name, label, type, length
  from dictionary.columns
  where libname='HMDA24'
    and memname='ESLFCU'
    and (lowcase(name) contains 'fee'
      or lowcase(name) contains 'cost'
      or lowcase(name) contains 'charge'
      or lowcase(name) contains 'origination'
      or lowcase(name) contains 'closing'
      or lowcase(name) contains 'total_loan'
      or lowcase(name) contains 'underwrit'
      or lowcase(label) contains 'fee'
      or lowcase(label) contains 'cost'
      or lowcase(label) contains 'charge'
      or lowcase(label) contains 'origination')
  order by name;
quit;